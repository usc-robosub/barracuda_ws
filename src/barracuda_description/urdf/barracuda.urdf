  <!-- Imaging Sonar Sensor -->
  <gazebo reference="barracuda/ping360_link">
    <sensor name="ping360_sensor" type="ray">
      <pose> 0 0 0 0 0 0 </pose>
      <visualize>true</visualize>
      <!-- Scan speed of actual sensor depends on range setting -->
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <!-- Assuming 360 for now, might be 400 if sensor uses gradians -->
            <samples>360</samples>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.75</min>
          <max>50</max>
        </range>
      </ray>
      <plugin filename="libgazebo_ros_laser.so" name="imaging_sonar">
        <topicName>barracuda/sonar/scan</topicName>
